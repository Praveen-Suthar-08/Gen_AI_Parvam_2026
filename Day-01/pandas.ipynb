    "import pandas as pd\n",
    "\n",
    "# create a simple DataFrame\n",
    "data = {\n",
    "    \"name\": [\"Alice\", \"Bob\", \"Charlie\"],\n",
    "    \"age\": [25, 32, 37],\n",
    "    \"score\": [88.5, 92.0, 79.5]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "# show the DataFrame\n",
    "print(df)\n",
    "\n",
    "# basic operations\n",
    "print(df.describe())\n",
    "print(df[df[\"age\"] > 30])"
   ]
